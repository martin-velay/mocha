{
  name: "cva6_cheri",
  target_dir: "cva6_cheri",

  upstream: {
    url: "https://github.com/lowRISC/cva6-cheri.git",
    rev: "mocha",
  },

  exclude_from_upstream: [
    // Broken build files.
    "ariane.core",
    // CI configurations.
    ".github",
    ".gitlab-ci",
    // External dependencies.
    "core/cvfpu",
    "corev_apu",
    "vendor",
    "verif",
  ]
}
